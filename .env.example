# Motor de traducción activo: deepl | google | azure
TRANSLATION_ENGINE=deepl

# Ruta de instalación de Dwarf Fortress
DF_INSTALL_PATH=D:/SteamLibrary/steamapps/common/Dwarf Fortress

# --- API Keys (solo la del motor activo es obligatoria) ---

# DeepL: https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Google Cloud Translation: https://cloud.google.com/translate/docs/setup
GOOGLE_API_KEY=

# Azure Translator: https://learn.microsoft.com/en-us/azure/cognitive-services/translator/
AZURE_API_KEY=
AZURE_REGION=westeurope

# --- Preferencias ---
# Pitido en consola al recibir una traducción (true / false)
BEEP_ENABLED=true

# Mostrar alertas de mismatch de tokens (true / false)
SHOW_MARKUP_WARNINGS=false
